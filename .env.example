# MongoDB Atlas Configuration
# Copy this file to .env and update with your actual MongoDB Atlas credentials

# MongoDB Atlas Connection String
# Get this from MongoDB Atlas -> Connect -> Drivers
MONGODB_URI=mongodb+srv://your-username:your-password@finance-tracker.mongodb.net/finance-tracker?retryWrites=true&w=majority

# Database Name
MONGODB_DATABASE=finance-tracker

# Server Port
SERVER_PORT=8080

# Instructions:
# 1. Go to MongoDB Atlas (https://cloud.mongodb.com)
# 2. Create a free cluster or use existing one
# 3. Create a database user with read/write permissions
# 4. Get the connection string from Connect -> Drivers
# 5. Replace 'your-username' and 'your-password' with actual credentials
# 6. Copy this file to .env (remove .example extension)
# 7. Run the application with: ./mvnw spring-boot:run
